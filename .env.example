INKDASH_HOST=0.0.0.0
INKDASH_PORT=8787
INKDASH_API_KEY=change-me
INKDASH_REFRESH_SECONDS=600

# Optional. Set this if KOReader cannot use the Host header to reach images.
# Example: http://192.168.1.20:8787
INKDASH_PUBLIC_BASE_URL=

# auto, portrait, landscape, rotated
INKDASH_ORIENTATION=auto

INKDASH_DEFAULT_WIDTH=600
INKDASH_DEFAULT_HEIGHT=800
INKDASH_SCREENS_DIR=public/screens
INKDASH_RSVG_CONVERT=rsvg-convert

# Shared timezone for rendering, calendar display, and weather requests.
INKDASH_TIMEZONE=Asia/Shanghai
# zh-CN or en. Controls admin text and generated dashboard labels.
INKDASH_LANGUAGE=zh-CN
INKDASH_HTTP_TIMEOUT_SECONDS=10

# Weather via Open-Meteo. Set latitude and longitude to enable.
INKDASH_WEATHER_PROVIDER=openmeteo
INKDASH_WEATHER_LAT=
INKDASH_WEATHER_LON=
INKDASH_WEATHER_LOCATION=Shanghai

# Weather via Caiyun. Set provider=caiyun and provide a token.
INKDASH_CAIYUN_TOKEN=
INKDASH_CAIYUN_LANG=zh_CN
INKDASH_CAIYUN_UNIT=metric

# Google Calendar via the private "Secret address in iCal format" URL.
# Keep this secret. For multiple calendars, separate URLs with commas.
INKDASH_CALENDAR_ICS_URL=
INKDASH_CALENDAR_ICS_URLS=
INKDASH_CALENDAR_LOOKAHEAD_DAYS=7
INKDASH_CALENDAR_MAX_EVENTS=4
INKDASH_CALENDAR_MAX_BYTES=26214400
INKDASH_CALENDAR_CACHE_SECONDS=900

# Codex usage reads local Codex session JSONL. If the newest JSONL is stale,
# the server briefly opens the Codex CLI and sends /status to refresh it.
INKDASH_CODEX_ENABLED=true
INKDASH_CODEX_CLI=codex
INKDASH_CODEX_CWD=.
INKDASH_CODEX_MODEL=
INKDASH_CODEX_JSONL_ROOT=~/.codex/sessions
INKDASH_CODEX_JSONL_STALE_SECONDS=300
INKDASH_CODEX_TIMEOUT_SECONDS=60
INKDASH_CODEX_CACHE_SECONDS=300
INKDASH_CODEX_STATUS_WAIT_SECONDS=12
